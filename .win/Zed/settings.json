{
  "theme": "One Dark",
  "icon_theme": "Zed (Default)",
  "tab_size": 2,
  "remove_trailing_whitespace_on_save": true,
  "auto_indent": true,
  "base_keymap": "VSCode",
  "ui_font_family": ".ZedSans",
  "ui_font_weight": 400,
  "ui_font_size": 15,
  "buffer_font_family": "Consolas",
  "buffer_font_fallbacks": ["Noto Sans JP", "Yu Gothic UI"], // 日本語用のフォント
  "buffer_font_size": 14,
  "buffer_font_weight": 400,
  "buffer_line_height": { "custom": 1.33 }, // Line height "comfortable" (1.618), "standard" (1.3) or custom: `{ "custom": 2 }`
  "terminal": {
    "font_family": "Consolas",
    "font_size": 14,
    "line_height": { "custom": 1.33 },
    "cursor_shape": "bar",
    "blinking": "on",
    "shell": {
      "with_arguments": {
        "program": "C:\\Program Files\\Git\\bin\\bash.exe",
        "args": ["--login"],
      },
    },
    "dock": "bottom", // position of integrated terminal
    "default_height": 240,
  },
  "collaboration_panel": {
    "button": false,
  },
}
